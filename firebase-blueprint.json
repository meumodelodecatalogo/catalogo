{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product in the pizzeria catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the product" },
        "description": { "type": "string", "description": "The description of the product" },
        "price": { "type": "number", "description": "The price of the product" },
        "category": { "type": "string", "description": "The category of the product" },
        "imageUrl": { "type": "string", "description": "The image URL of the product" },
        "active": { "type": "boolean", "description": "Whether the product is active" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tags for the product" }
      },
      "required": ["name", "price", "category", "imageUrl", "active"]
    }
  },
  "firestore": {
    "products": {
      "schema": "Product",
      "description": "Collection of products"
    }
  }
}
